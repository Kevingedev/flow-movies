---
import Layout from '../layouts/Layout.astro';

const response = await fetch('https://api.themoviedb.org/3/movie/popular?language=es-ES', {
  headers: {
    Authorization: `Bearer ${import.meta.env.TMDB_TOKEN}`,
    accept: 'application/json',
  }
});

const data = await response.json();

// ESTO SE VERÁ EN TU TERMINAL DE VS CODE
console.log("Datos de la API:", data.results[0]); 
---

<Layout title="Flow Movies - Home">
	<h1 class="text-4xl font-bold text-center mt-10">
		Bienvenido a Flow Movies 🍿
	</h1>
	<p class="text-center text-gray-400 mt-4">
		Tu catálogo de cine más rápido y fluido.
	</p>	
</Layout>
