---
import Layout from "../layouts/Layout.astro";
import {
  getUpcomingMovies,
  getOnTheAirTV,
  getPopularPeople,
} from "../services/tmdb";

// Components
import SectionHeader from "../components/ui/SectionHeader.astro";
import NewsHero from "../components/movies/NewsHero.astro";
import TVNewsCard from "../components/shows/TVNewsCard.astro";
import PersonCard from "../components/ui/PersonCard.astro";

// Parallel Data Fetching for performance (Server Side)
const [upcomingData, newEpisodesData, popularPeopleData] = await Promise.all([
  getUpcomingMovies(),
  getOnTheAirTV(),
  getPopularPeople(),
]);

const upcomingMovies = upcomingData.results.slice(0, 3);
const newEpisodes = newEpisodesData.results;
const popularPeople = popularPeopleData.results.slice(0, 12); // Optimized for grid
---

<Layout title="Novedades | Flow Movies">
  <div class="min-h-screen bg-[#000000] text-white">
    <!-- SUB-NAVIGATION: NAV-LINK LIST -->
    <div
      class="sticky top-[72px] z-40 bg-black/90 backdrop-blur-2xl border-b border-white/5 py-5"
    >
      <div
        class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-16 flex items-center justify-between"
      >
        <div class="flex gap-10 overflow-x-auto no-scrollbar scroll-smooth">
          <a href="#proximamente" class="group relative py-2">
            <span
              class="text-xs font-black uppercase tracking-[0.25em] text-neutral-400 group-hover:text-white transition-colors"
              >Próximamente</span
            >
            <span
              class="absolute bottom-0 left-0 w-0 h-[2px] bg-flow-accent transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
          <a href="#nuevos-episodios" class="group relative py-2">
            <span
              class="text-xs font-black uppercase tracking-[0.25em] text-neutral-400 group-hover:text-white transition-colors"
              >Episodios</span
            >
            <span
              class="absolute bottom-0 left-0 w-0 h-[2px] bg-flow-accent transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
          <a href="#celebridades" class="group relative py-2">
            <span
              class="text-xs font-black uppercase tracking-[0.25em] text-neutral-400 group-hover:text-white transition-colors"
              >Estrellas</span
            >
            <span
              class="absolute bottom-0 left-0 w-0 h-[2px] bg-flow-accent transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
        </div>

        <div class="hidden md:flex items-center gap-4">
          <span
            class="px-4 py-1.5 bg-neutral-900 rounded-full border border-white/5 text-[10px] font-black uppercase tracking-widest text-neutral-500"
          >
            Actualizado Hoy
          </span>
        </div>
      </div>
    </div>

    <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-16 py-12 space-y-32">
      <!-- 1. HERO SECTION: UPCOMING MOVIES -->
      <section id="proximamente" class="scroll-mt-40 mt-12">
        <SectionHeader title="Próximamente" badge="Cinemas 2026" />
        <NewsHero movies={upcomingMovies} />
      </section>

      <!-- 2. TV SERIES: ON THE AIR -->
      <section id="nuevos-episodios" class="scroll-mt-40">
        <SectionHeader
          title="Nuevos Episodios"
          badge="En Directo"
          pulse={true}
        />

        <div class="relative mt-10">
          <div
            id="episodes-carousel"
            class="flex gap-6 overflow-x-auto pb-12 snap-x snap-mandatory no-scrollbar scroll-smooth py-5"
          >
            {newEpisodes.map((show) => <TVNewsCard show={show} />)}
          </div>

          <!-- Navigation Buttons -->
          <button
            id="carousel-prev-btn"
            type="button"
            aria-label="Desplazar carrusel hacia la izquierda"
            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 hidden lg:flex items-center justify-center w-12 h-12 bg-white/5 backdrop-blur-md rounded-full border border-white/10 text-flow-accent hover:bg-white/10 hover:border-white/20 hover:scale-110 active:scale-95 transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:scale-100 z-10"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"
              ></path>
            </svg>
          </button>

          <button
            id="carousel-next-btn"
            type="button"
            aria-label="Desplazar carrusel hacia la derecha"
            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 hidden lg:flex items-center justify-center w-12 h-12 bg-white/5 backdrop-blur-md rounded-full border border-white/10 text-flow-accent hover:bg-white/10 hover:border-white/20 hover:scale-110 active:scale-95 transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:scale-100 z-10"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </button>
        </div>
      </section>

      <!-- 3. CELEBRITIES: POPULAR PEOPLE -->
      <section id="celebridades" class="scroll-mt-40">
        <SectionHeader title="Protagonistas" badge="Top Trending" />

        <div
          class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-8 gap-y-16 mt-16"
        >
          {popularPeople.map((person) => <PersonCard person={person} />)}
        </div>

        <div class="mt-24 border-t border-white/5 pt-12 text-center">
          <button
            class="px-12 py-5 bg-transparent border border-white/10 rounded-full text-xs font-black uppercase tracking-[0.3em] hover:bg-white hover:text-black hover:border-white transition-all duration-500"
          >
            Cargar más estrellas
          </button>
        </div>
      </section>
    </div>

    <!-- FOOTER DECORATION -->
    <div
      class="h-64 bg-gradient-to-t from-flow-accent/5 to-transparent pointer-events-none"
    >
    </div>
  </div>

  <style>
    /* HIDE SCROLLBAR BUT KEEP FUNCTIONALITY */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script>
    // Carrusel de episodios - Navegación con botones
    (function initCarousel() {
      const carouselEl = document.getElementById("episodes-carousel");
      const prevBtnEl = document.getElementById("carousel-prev-btn");
      const nextBtnEl = document.getElementById("carousel-next-btn");

      if (!carouselEl || !prevBtnEl || !nextBtnEl) return;

      const carousel = carouselEl as HTMLElement;
      const prevBtn = prevBtnEl as HTMLButtonElement;
      const nextBtn = nextBtnEl as HTMLButtonElement;

      // Función para actualizar el estado de los botones
      function updateButtonStates() {
        const { scrollLeft, scrollWidth, clientWidth } = carousel;
        const isAtStart = scrollLeft <= 0;
        const isAtEnd = scrollLeft >= scrollWidth - clientWidth - 1;

        prevBtn.disabled = isAtStart;
        nextBtn.disabled = isAtEnd;
      }

      // Desplazar hacia la derecha
      nextBtn.addEventListener("click", () => {
        const cardElement = carousel.querySelector("a") as HTMLElement | null;
        const cardWidth = cardElement?.getBoundingClientRect().width || 400;
        const gap = 24; // gap-6 = 1.5rem = 24px
        const scrollAmount = cardWidth + gap;

        carousel.scrollBy({
          left: scrollAmount,
          behavior: "smooth",
        });
      });

      // Desplazar hacia la izquierda
      prevBtn.addEventListener("click", () => {
        const cardElement = carousel.querySelector("a") as HTMLElement | null;
        const cardWidth = cardElement?.getBoundingClientRect().width || 400;
        const gap = 24; // gap-6 = 1.5rem = 24px
        const scrollAmount = cardWidth + gap;

        carousel.scrollBy({
          left: -scrollAmount,
          behavior: "smooth",
        });
      });

      // Actualizar estado de botones al hacer scroll
      carousel.addEventListener("scroll", updateButtonStates);

      // Actualizar estado inicial
      updateButtonStates();

      // Actualizar estado al redimensionar la ventana
      let resizeTimeout: ReturnType<typeof setTimeout>;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(updateButtonStates, 150);
      });
    })();
  </script>
</Layout>
