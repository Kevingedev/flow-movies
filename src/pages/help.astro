---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const categories = [
    {
        name: "Account",
        icon: "lucide:user",
        description:
            "Manage your subscription, profiles, and user preferences.",
        color: "from-red-500/20",
    },
    {
        name: "Billing",
        icon: "lucide:credit-card",
        description: "Payments, invoices, payment methods, and billing cycles.",
        color: "from-blue-500/20",
    },
    {
        name: "Devices",
        icon: "lucide:monitor-smartphone",
        description:
            "Configure Flow Movies on TV, mobile, tablets, and consoles.",
        color: "from-purple-500/20",
    },
    {
        name: "Playback",
        icon: "lucide:play-circle",
        description:
            "Troubleshooting video, audio, and streaming quality.",
        color: "from-orange-500/20",
    },
    {
        name: "Privacy",
        icon: "lucide:lock",
        description: "Control your data, account security, and privacy.",
        color: "from-emerald-500/20",
    },
    {
        name: "Contact",
        icon: "lucide:message-circle",
        description: "Direct support, suggestions, and commercial inquiries.",
        color: "from-pink-500/20",
    },
];

const faqs = [
    {
        question: "How can I cancel my subscription?",
        answer: "You can cancel your subscription at any time from the 'Account Settings' section. Once the cancellation is confirmed, you will continue to have access to the service until your current billing period ends. There are no cancellation fees.",
    },
    {
        question: "How many devices can I watch content on?",
        answer: "The number of simultaneous devices depends on your subscription plan. The Premium plan allows up to 4 screens simultaneously in 4K HDR resolution. You can manage your linked devices from the control panel.",
    },
    {
        question: "How do I change the video quality?",
        answer: "Flow Movies automatically adjusts the quality according to your internet connection. However, you can force a specific quality (Data Saver, Standard, or Maximum) from the settings menu during playback.",
    },
    {
        question: "Can I download content to watch offline?",
        answer: "Yes! Most of our titles are available for download on mobile devices and tablets. Look for the download icon next to the content title. Downloads expire 30 days or 48 hours after starting playback.",
    },
    {
        question: "How do I recover my password?",
        answer: "If you have forgotten your password, click on 'Forgot your password?' on the login screen. We will send you a recovery link to your registered email address. For security, the link expires in one hour.",
    },
];
---

<Layout title="Help Center | Flow Movies">
    <div class="relative min-h-screen bg-flow-bg overflow-hidden pb-32">
        <!-- Background Decoration -->
        <div
            class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-flow-accent/10 blur-[120px] rounded-full animate-pulse-slow -z-10"
        >
        </div>
        <div
            class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-flow-accent/5 blur-[100px] rounded-full animate-float -z-10"
        >
        </div>

        <div
            class="max-w-7xl mx-auto px-6 lg:px-8 space-y-32 mt-35 relative z-10"
        >
            <!-- 1. Hero Search Section -->
            <section
                class="max-w-5xl mx-auto text-center space-y-12 py-20 relative"
            >
                <div class="space-y-6">
                    <div
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-flow-accent text-xs font-black uppercase tracking-[0.3em] animate-fade-in"
                    >
                        <span class="relative flex h-2 w-2">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-flow-accent opacity-75"
                            ></span>
                            <span
                                class="relative inline-flex rounded-full h-2 w-2 bg-flow-accent"
                            ></span>
                        </span>
                        Soporte 24/7 Activo
                    </div>
                    <h1
                        class="text-5xl md:text-7xl font-black tracking-tighter text-white leading-none italic"
                    >
                        ¿How can I<br />
                        <span
                            class="bg-gradient-to-r from-white via-white to-white/30 bg-clip-text text-transparent italic"
                            >help you today?</span
                        >
                    </h1>
                    <p
                        class="text-flow-sub text-xl md:text-2xl max-w-2xl mx-auto font-medium leading-relaxed"
                    >
                        Tell us what you need and we'll help you find the
                        perfect solution.
                    </p>
                </div>

                <div class="relative max-w-2xl mx-auto group">
                    <!-- Glow effect behind input -->
                    <div
                        class="absolute -inset-2 bg-flow-accent/20 rounded-[2.5rem] blur-2xl opacity-0 group-focus-within:opacity-100 transition duration-1000"
                    >
                    </div>

                    <div
                        class="relative flex items-center bg-white/5 backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-2 focus-within:border-flow-accent/40 focus-within:shadow-flow-accent/10 transition-all duration-500 shadow-2xl"
                    >
                        <div
                            class="pl-6 text-flow-sub transition-colors group-focus-within:text-flow-accent"
                        >
                            <Icon name="lucide:search" class="w-7 h-7" />
                        </div>
                        <input
                            type="text"
                            placeholder="¿How can I help you today?"
                            class="w-full py-5 px-6 bg-transparent border-none outline-none text-white placeholder:text-white/20 text-xl font-medium"
                        />
                        <button
                            class="bg-flow-accent hover:bg-red-700 text-white px-8 py-6 rounded-full font-black uppercase text-xs tracking-widest transition-all hover:shadow-[0_0_20px_rgba(220,38,38,0.5)] active:scale-95 hidden md:block"
                        >
                            Search
                        </button>
                    </div>
                </div>
            </section>

            <!-- 2. Categories Grid -->
            <section class="space-y-12">
                <div
                    class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-white/5 pb-8"
                >
                    <div class="space-y-2">
                        <h2
                            class="text-4xl font-black tracking-tight text-white"
                        >
                            Explore Topics
                        </h2>
                        <p class="text-flow-sub font-medium">
                            Select a category to view detailed articles.
                        </p>
                    </div>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
                >
                    {
                        categories.map((cat) => (
                            <a
                                href={`#${cat.name.toLowerCase()}`}
                                class="group relative p-10 bg-white/5 backdrop-blur-2xl border border-white/10 rounded-[2.5rem] overflow-hidden transition-all duration-700 hover:border-flow-accent/30 hover:shadow-flow-accent/10 flex flex-col justify-between min-h-[320px]"
                            >
                                <div class="relative z-10 space-y-8">
                                    <div class="w-16 h-16 bg-neutral-900 border border-white/10 rounded-2xl flex items-center justify-center text-white transition-all duration-500 shadow-2xl">
                                        <Icon name={cat.icon} class="w-8 h-8" />
                                    </div>
                                    <div class="space-y-3">
                                        <span class="text-[10px] text-flow-accent font-black uppercase tracking-[0.3em]">
                                            Category
                                        </span>
                                        <h3 class="text-3xl font-black text-white transition-colors duration-500">
                                            {cat.name}
                                        </h3>
                                        <p class="text-flow-sub text-base font-medium leading-relaxed">
                                            {cat.description}
                                        </p>
                                    </div>
                                </div>

                                <div class="relative z-10 mt-10">
                                    <div class="inline-flex items-center gap-3 bg-white/5 border border-white/10 text-white px-8 py-3 rounded-full font-black uppercase text-[10px] tracking-widest transition-all duration-300 group-hover:bg-white group-hover:text-black group-hover:scale-105 active:scale-95 hover:drop-shadow-[0_0_15px_rgba(220,220,220,0.1)]">
                                        <span>Explore</span>
                                        <Icon
                                            name="lucide:arrow-right"
                                            class="w-4 h-4 transition-transform group-hover:translate-x-1"
                                        />
                                    </div>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </section>

            <!-- 3. FAQs Section -->
            <section class="max-w-4xl mx-auto space-y-16 py-10">
                <div class="text-center space-y-6">
                    <h2 class="text-5xl font-black tracking-tight text-white">
                        Frequently Asked Questions
                    </h2>
                    <p
                        class="text-flow-sub text-lg font-medium max-w-xl mx-auto leading-relaxed"
                    >
                        Quick answers to the most common questions from our
                        community.
                    </p>
                </div>

                <div class="space-y-6">
                    {
                        faqs.map((faq) => (
                            <details class="group bg-white/5 backdrop-blur-2xl border border-white/10 rounded-[2rem] transition-all duration-500 open:border-flow-accent/30 overflow-hidden">
                                <summary class="flex items-center justify-between p-8 cursor-pointer list-none select-none">
                                    <span class="text-xl font-bold pr-10 text-white group-hover:text-flow-accent group-open:text-white transition-colors duration-300">
                                        {faq.question}
                                    </span>
                                    <div class="faq-icon-container relative flex-shrink-0 w-12 h-12 rounded-xl bg-neutral-900 border border-white/10 flex items-center justify-center transition-all duration-500">
                                        <Icon
                                            name="lucide:plus"
                                            class="w-6 h-6 text-white absolute transition-all duration-500 group-open:opacity-0 group-open:scale-50"
                                        />
                                        <Icon
                                            name="lucide:minus"
                                            class="w-6 h-6 text-white absolute transition-all duration-500 opacity-0 scale-50 group-open:opacity-100 group-open:scale-100"
                                        />
                                    </div>
                                </summary>
                                <div class="px-8 pb-8 pt-2">
                                    <div class="h-px w-full bg-gradient-to-r from-flow-accent/50 to-transparent mb-8" />
                                    <p class="text-flow-sub text-lg leading-relaxed font-medium animate-fade-in">
                                        {faq.answer}
                                    </p>
                                </div>
                            </details>
                        ))
                    }
                </div>
            </section>

            <!-- 4. Contact/Support Section -->
            <section class="pb-20">
                <div
                    class="relative p-12 md:p-24 text-center space-y-12 bg-white/5 backdrop-blur-3xl border border-white/10 rounded-[4rem] overflow-hidden shadow-2xl"
                >
                    <div
                        class="absolute top-0 left-0 w-full h-[500px] bg-flow-accent/5 blur-[120px] -z-10 animate-pulse-slow"
                    >
                    </div>

                    <div class="space-y-6 relative">
                        <div
                            class="w-16 h-1 bg-flow-accent mx-auto rounded-full mb-8"
                        >
                        </div>
                        <h2
                            class="text-4xl md:text-6xl font-black tracking-tight text-white leading-none italic"
                        >
                            Still need <br />
                            <span
                                class="bg-gradient-to-r from-white via-white to-white/30 bg-clip-text text-transparent italic"
                                >help?</span
                            >
                        </h2>
                        <p
                            class="text-flow-sub text-xl max-w-2xl mx-auto font-medium leading-relaxed"
                        >
                            If you didn't find what you were looking for, our
                            team of experts is ready to help you personally.
                        </p>
                    </div>

                    <div
                        class="flex flex-col sm:flex-row items-center justify-center gap-6 relative"
                    >
                        <a
                            href="#"
                            class="group px-12 py-5 bg-flow-accent text-white font-black uppercase text-xs tracking-widest rounded-full transition-all hover:scale-105 active:scale-95 shadow-xl shadow-flow-accent/20 hover:drop-shadow-[0_0_15px_rgba(220,38,38,0.4)] flex items-center gap-4"
                        >
                            <Icon
                                name="lucide:message-circle"
                                class="w-5 h-5"
                            />
                            <span>Live Chat</span>
                        </a>
                        <a
                            href="#"
                            class="group px-12 py-5 bg-transparent border border-white/10 text-white font-black uppercase text-xs tracking-widest rounded-full transition-all hover:bg-white/5 hover:scale-105 active:scale-95 flex items-center gap-4"
                        >
                            <Icon name="lucide:ticket" class="w-5 h-5" />
                            <span>Send Ticket</span>
                        </a>
                    </div>
                </div>
            </section>
        </div>
    </div>
</Layout>

<style>
    @keyframes float {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-20px);
        }
    }

    .animate-float {
        animation: float 10s ease-in-out infinite;
    }

    @keyframes pulse-slow {
        0%,
        100% {
            opacity: 0.3;
            transform: scale(1);
        }
        50% {
            opacity: 0.6;
            transform: scale(1.1);
        }
    }

    .animate-pulse-slow {
        animation: pulse-slow 8s ease-in-out infinite;
    }

    @keyframes fade-in {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in {
        animation: fade-in 1s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }

    summary::-webkit-details-marker {
        display: none;
    }
</style>
