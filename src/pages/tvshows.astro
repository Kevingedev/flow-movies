---
import { Icon } from "astro-icon/components";
import GridShowCard from "../components/shows/GridShowCard.astro";
import CategoryFilter from "../components/ui/CategoryFilter.astro";
import Layout from "../layouts/Layout.astro";
import { getTvShows, getGenresShows, getDiscoverShows } from "../services/tmdb";
import type { TVShow } from "../types/tvshow";

const { searchParams } = Astro.url;
const genre = searchParams.get("genre");
const page = parseInt(searchParams.get("page") || "1");

let shows: TVShow[] = [];
// let totalPages = 1;
let title = "TV Shows";

try {
    if (genre) {
        
        const [showResponse, genreList] = await Promise.all([
            getDiscoverShows(genre, page),
            getGenresShows(),
        ]);

        shows = showResponse.results;
        title = genreList.find((g) => g.id === parseInt(genre))?.name || "TV Shows";
    
    }else{
        const showResponse = await getTvShows(page);
        shows = showResponse.results.sort(
            (a: TVShow, b: TVShow) => b.vote_average - a.vote_average,
        );
        // totalPages = showResponse.total_pages;
        title = "All TV Shows";

    }
} catch (error) {
    console.error("[TVShowsPage] Error loading TV show data:", error);
}
const getNextPageUrl = () => {
    const params = new URLSearchParams(searchParams);
    params.set("page", (page + 1).toString());
    return `?${params.toString()}`;
};

const getPrevPageUrl = () => {
    if (page <= 1) return null;
    const params = new URLSearchParams(searchParams);
    params.set("page", (page - 1).toString());
    return `?${params.toString()}`;
};

---

<Layout title={title}>
    <div class="min-h-screen bg-black pt-28 pb-12 px-4 sm:px-6 lg:px-12">
        <div class="max-w-[1920px] mx-auto">
            <!-- Header -->
            <header class="flex flex-col gap-6 mb-10">
                <div class="flex items-center gap-4">
                    <a
                        href="/"
                        class="p-2 rounded-full bg-white/5 hover:bg-white/10 text-white transition-colors group"
                        aria-label="Go back"
                    >
                        <Icon
                            name="lucide:chevron-left"
                            class="size-6 group-hover:-translate-x-0.5 transition-transform"
                        />
                    </a>
                    <h1
                        class="text-3xl md:text-4xl font-bold text-white tracking-tight"
                    >
                        TV Shows
                    </h1>
                </div>
                <div
                    class="w-full md:overflow-x-auto overflow-visible pb-2 no-scrollbar"
                >
                </div>
                <CategoryFilter activeCategory={genre || "all"} type="tv" />
            </header>

            {
                shows.length > 0 ? (
                    <>
                        <div
                            id="movie-grid"
                            class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-8"
                        >
                            {shows.map((show, index) => (
                                <div
                                    class={`col-span-1 transition-all duration-700 ease-out ${index >= 10 ? "hidden opacity-0 translate-y-8 hidden-movie" : ""}`}
                                >
                                    <GridShowCard show={show} />
                                </div>
                            ))}
                        </div>

                        {shows.length > 10 && (
                            <div
                                class="flex justify-center mt-8"
                                id="show-more-container"
                            >
                                <button
                                    id="show-more-btn"
                                    class="group relative px-8 py-3 rounded-full bg-white/5 backdrop-blur-md border border-white/10 text-white font-medium hover:bg-white/10 hover:border-white/20 hover:scale-105 hover:shadow-lg hover:shadow-flow-accent/20 transition-all duration-300 ease-out"
                                >
                                    <span class="relative z-10 flex items-center gap-2">
                                        Mostrar más
                                        <Icon
                                            name="lucide:chevron-down"
                                            class="size-4 transition-transform group-hover:translate-y-1"
                                        />
                                    </span>
                                </button>
                            </div>
                        )}
                    </>
                ) : (
                    <div class="flex flex-col items-center justify-center py-20 text-center">
                        <p class="text-gray-400">No movies found.</p>
                    </div>
                )
            }
            <script>
                document.addEventListener("astro:page-load", () => {
                    const showMoreBtn =
                        document.getElementById("show-more-btn");
                    const hiddenMovies =
                        document.querySelectorAll(".hidden-movie");
                    const container = document.getElementById(
                        "show-more-container",
                    );

                    if (showMoreBtn) {
                        showMoreBtn.addEventListener("click", () => {
                            // First remove hidden to allow layout to calculate
                            hiddenMovies.forEach((movie) => {
                                movie.classList.remove("hidden");
                            });

                            // Then trigger animations with a small delay and staggering
                            requestAnimationFrame(() => {
                                hiddenMovies.forEach((movie, index) => {
                                    setTimeout(() => {
                                        movie.classList.remove(
                                            "opacity-0",
                                            "translate-y-8",
                                        );
                                    }, index * 50); // 50ms staggered delay
                                });
                            });

                            if (container) {
                                container.style.display = "none";
                            }
                        });
                    }
                });
            </script>   
            <!-- Pagination (Simple) -->
            <div class="mt-12 flex justify-center items-center gap-4">
                {
                    getPrevPageUrl() ? (
                        <a
                            href={getPrevPageUrl()}
                            class="px-6 py-3 rounded-full bg-white/5 hover:bg-white/10 text-white font-medium transition-colors border border-white/10"
                        >
                            Previous
                        </a>
                    ) : (
                        <button
                            disabled
                            class="px-6 py-3 rounded-full bg-white/5 text-gray-500 font-medium border border-white/5 cursor-not-allowed"
                        >
                            Previous
                        </button>
                    )
                }

                <span class="text-sm text-gray-400"
                    >Page {page}</span
                >

                <a
                    href={getNextPageUrl()}
                    class="px-6 py-3 rounded-full bg-flow-accent hover:bg-red-700 text-white font-medium transition-colors shadow-lg shadow-red-900/20"
                >
                    Next Page
                </a>
            </div>
        </div>
    </div>
</Layout>