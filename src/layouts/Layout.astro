---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title} | Flow Movies</title>
    <ClientRouter />
  </head>
  <body
    class="bg-flow-bg text-white font-sans antialiased selection:bg-flow-accent/30 flex flex-col min-h-screen"
  >
    <Header />
    <main class="max-w-7xl mx-auto p-4 flex-grow w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>
