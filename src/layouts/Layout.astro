---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title} | Flow Movies</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body
    class="bg-flow-bg text-white font-sans antialiased selection:bg-flow-accent/30 flex flex-col min-h-screen"
  >
    <Header />
    <main class="flex-grow w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>
