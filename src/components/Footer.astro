---
import Logo from "./header/Logo.astro";
import FooterColumn from "./footer/FooterColumn.astro";
import SocialIcons from "./footer/SocialIcons.astro";

const footerLinks = {
    explorar: [
        { label: "Home", href: "/" },
        { label: "Movies", href: "/movies" },
        { label: "Series", href: "/tvshows" },
        { label: "New", href: "/new" },
    ],
    soporte: [
        { label: "Help Center", href: "/help" },
        { label: "Terms of Service", href: "/terms" },
        { label: "Privacy", href: "/privacy" },
    ],
    cuenta: [
        { label: "My List", href: "/list" },
        { label: "Profile", href: "/profile" },
        { label: "Settings", href: "/settings" },
    ],
};
---

<footer class="bg-flow-bg border-t border-flow-border/50 pt-16 pb-8 mt-20">
    <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-12">
        <div
            class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-12 mb-16"
        >
            <!-- Logo & Description Section -->
            <div class="col-span-2 lg:col-span-2 flex flex-col gap-6">
                <div>
                    <Logo />
                </div>
                <p class="text-flow-sub text-sm leading-relaxed max-w-xs">
                    Your ultimate destination for seamless entertainment. Enjoy the best movies and series with a premium and minimalist experience.
                </p>
                <SocialIcons />
            </div>

            <!-- Navigation Columns -->
            <FooterColumn title="Explore" links={footerLinks.explorar} />
            <FooterColumn title="Support" links={footerLinks.soporte} />
            <FooterColumn title="Account" links={footerLinks.cuenta} />
        </div>

        <!-- Bottom Section -->
        <div
            class="pt-8 border-t border-flow-border/30 flex flex-col md:flex-row justify-between items-center gap-4"
        >
            <p class="text-flow-sub text-xs">
                © {new Date().getFullYear()} Flow Movies. All rights reserved..
            </p>
            <div class="flex gap-6">
                <a
                    href="#"
                    class="text-flow-sub hover:text-white text-xs transition-colors transition-colors"
                    >Cookies</a
                >
                <a
                    href="#"
                    class="text-flow-sub hover:text-white text-xs transition-colors transition-colors"
                    >Legal</a
                >
                <a
                    href="#"
                    class="text-flow-sub hover:text-white text-xs transition-colors transition-colors"
                    >Advertising</a
                >
            </div>
        </div>
    </div>
</footer>
