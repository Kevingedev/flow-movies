---

---

<div class="relative flex items-center group">
    <!-- Glass Container -->
    <div
        class="relative flex items-center transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]
                w-10 sm:w-56 lg:w-72 focus-within:w-48 sm:focus-within:w-64 lg:focus-within:w-80"
    >
        <!-- Search Icon -->
        <div class="absolute left-3 flex items-center pointer-events-none z-10">
            <svg
                class="h-4 w-4 text-flow-sub group-focus-within:text-flow-accent transition-colors duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
        </div>

        <!-- Glass Input -->
        <input
            type="text"
            class="w-full pl-10 pr-4 py-2 bg-white/[0.03] backdrop-blur-xl border border-white/10 rounded-full
                   text-flow-text placeholder-transparent sm:placeholder-flow-sub/50
                   focus:placeholder-flow-sub/70 focus:outline-none focus:bg-white/[0.07]
                   focus:border-flow-accent/40 focus:ring-4 focus:ring-flow-accent/5
                   transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]
                   hover:bg-white/[0.06] hover:border-white/20"
            placeholder="Search titles..."
        />

        <!-- Mobile Touch Target / Icon Overlay -->
        <div
            class="absolute inset-0 rounded-full pointer-events-none ring-1 ring-white/5 group-hover:ring-white/10 transition-all duration-300"
        >
        </div>
    </div>
</div>
