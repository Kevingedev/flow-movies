---
import { Icon } from "astro-icon/components";
import SearchResults from "./SearchResults.astro";
---

<div class="relative flex items-center group" id="search-container">
    <form
        action="/search"
        method="GET"
        class="relative flex items-center transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] mr-4
                w-10 sm:w-56 lg:w-72 focus-within:w-80 focus-within:-translate-x-40 sm:focus-within:translate-x-0 focus-within:bg-flow-bg xs:focus-within:w-64 sm:focus-within:w-64 lg:focus-within:w-80"
    >
        <div class="absolute left-3 flex items-center pointer-events-none z-10">
            <Icon
                name="lucide:search"
                class="size-4 fill-current text-white/[0.3]"
            />
        </div>

        <input
            id="search-input"
            name="q"
            type="text"
            autocomplete="off"
            class="w-full pl-10 pr-4 py-3 lg:py-2 bg-white/[0.03] backdrop-blur-xl border border-white/10 rounded-full
                   text-white placeholder-transparent sm:placeholder-white/30
                   focus:placeholder-white/50 focus:outline-none focus:bg-white/[0.07]
                   focus:border-flow-accent/40 focus:ring-4 focus:ring-flow-accent/5
                   transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]
                   hover:bg-white/[0.06] hover:border-white/20 focus-within:shadow-[0_0_20px_rgba(220,38,38,0.1)]"
            placeholder="Search movies or series ..."
        />

        <div
            id="search-loader"
            class="absolute bottom-1 left-4 right-4 h-[1.5px] overflow-hidden hidden"
        >
            <div class="h-full bg-flow-accent animate-loading-slide"></div>
        </div>

        <div
            class="absolute inset-0 rounded-full pointer-events-none ring-1 ring-transparent group-hover:ring-white/10 transition-all duration-300"
        >
        </div>
    </form>

    <SearchResults />
</div>

<style>
    @keyframes loading-slide {
        0% {
            transform: translateX(-100%);
        }
        100% {
            transform: translateX(100%);
        }
    }
    .animate-loading-slide {
        animation: loading-slide 1s infinite linear;
    }
</style>

<script>
    function setupSearch() {
        const container = document.getElementById("search-container");
        const searchInput = document.getElementById(
            "search-input",
        ) as HTMLInputElement;
        const searchResults = document.getElementById("search-results");
        const resultsList = document.getElementById("results-list");
        const loader = document.getElementById("search-loader");

        if (!searchInput || !searchResults || !resultsList || !container)
            return;

        let debounceTimer: ReturnType<typeof setTimeout>;

        const createItemTemplate = (item: any) => {
            const title = item.title || item.name;
            const date = item.release_date || item.first_air_date || "";
            const year = date ? date.split("-")[0] : "N/A";
            const rating = item.vote_average?.toFixed(1) || "0.0";
            const poster = item.poster_path
                ? `https://image.tmdb.org/t/p/w92${item.poster_path}`
                : "https://via.placeholder.com/92x138?text=No+Image";
            const link =
                item.media_type === "movie"
                    ? `/movie/${item.id}`
                    : `/tvshow/${item.id}`;

            return `
                <a href="${link}" class="flex items-center gap-4 p-3 hover:bg-white/5 border-l-2 border-transparent hover:border-flow-accent transition-all group">
                    <img src="${poster}" alt="${title}" class="w-12 h-16 object-cover rounded-md shadow-lg" loading="lazy" />
                    <div class="flex flex-col flex-1 overflow-hidden">
                        <span class="text-white font-medium truncate group-hover:text-flow-accent transition-colors">${title}</span>
                        <span class="text-xs text-flow-sub font-medium">${year}</span>
                    </div>
                    <div class="flex items-center gap-1 text-xs font-bold text-white bg-white/5 px-2 py-1 rounded-full border border-white/5 group-hover:border-flow-accent/30 transition-colors">
                        <svg class="w-3 h-3 text-red-500 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                        ${rating}
                    </div>
                </a>
            `;
        };

        const performSearch = async (query: string) => {
            if (query.trim().length < 2) {
                searchResults.classList.remove("show");
                return;
            }

            loader?.classList.remove("hidden");

            try {
                const response = await fetch(
                    `/api/search?q=${encodeURIComponent(query)}`,
                );
                const data = await response.json();

                const results = (data.results || [])
                    .sort(
                        (a: any, b: any) =>
                            (b.vote_average || 0) - (a.vote_average || 0),
                    )
                    .slice(0, 4);

                if (results.length > 0) {
                    resultsList.innerHTML = results
                        .map(createItemTemplate)
                        .join("");
                    searchResults.classList.add("show");
                } else {
                    searchResults.classList.remove("show");
                }
            } catch (error) {
                console.error("Search error:", error);
                searchResults.classList.remove("show");
            } finally {
                loader?.classList.add("hidden");
            }
        };

        const handleInput = (e: Event) => {
            clearTimeout(debounceTimer);
            const query = (e.target as HTMLInputElement).value;
            debounceTimer = setTimeout(() => performSearch(query), 300);
        };

        const handleClickOutside = (e: MouseEvent) => {
            if (!container.contains(e.target as Node)) {
                searchResults.classList.remove("show");
            }
        };

        const handleEscape = (e: KeyboardEvent) => {
            if (e.key === "Escape") {
                searchResults.classList.remove("show");
                searchInput.blur();
            }
        };

        const handleSubmit = () => {
            searchResults.classList.remove("show");
        };

        searchInput.addEventListener("input", handleInput);
        container
            .querySelector("form")
            ?.addEventListener("submit", handleSubmit);
        document.addEventListener("click", handleClickOutside);
        document.addEventListener("keydown", handleEscape);
    }

    // Initialize
    setupSearch();
    document.addEventListener("astro:page-load", setupSearch);
</script>
