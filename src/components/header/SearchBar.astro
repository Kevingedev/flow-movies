---
import { Icon } from "astro-icon/components";
---

<div class="relative flex items-center group">
    <!-- Glass Container -->
    <div
        class="relative flex items-center transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]
                w-10 sm:w-56 lg:w-72 focus-within:w-50 xs:focus-within:w-44 sm:focus-within:w-64 lg:focus-within:w-80"
    >
        <!-- Search Icon -->
        <div class="absolute left-3 flex items-center pointer-events-none z-10">
            <Icon name="lucide:search" class="size- fill-current text-white/[0.3]" />
        </div>

        <!-- Glass Input -->
        <input
            type="text"
            class="w-full pl-10 pr-4 py-3 lg:py-2 bg-white/[0.03] backdrop-blur-xl border border-white/10 rounded-full
                   text-flow-text placeholder-transparent sm:placeholder-flow-sub/50
                   focus:placeholder-flow-sub/70 focus:outline-none focus:bg-white/[0.07]
                   focus:border-flow-accent/40 focus:ring-4 focus:ring-flow-accent/5
                   transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]
                   hover:bg-white/[0.06] hover:border-white/20 focus-within:shadow-[0_0_20px_rgba(220,38,38,0.1)]"
            placeholder="Search titles..."
        />

        <!-- Mobile Touch Target / Icon Overlay -->
        <div
            class="absolute inset-0 rounded-full pointer-events-none ring-1 ring-transparent group-hover:ring-white/10 transition-all duration-300"
        >
        </div>
    </div>
</div>
