---
const currentPath = Astro.url.pathname;

const navItems = [
    { name: "Home", href: "/", active: currentPath === "/" },
    {
        name: "Movies",
        href: "/movies",
        active: currentPath.startsWith("/movies"),
    },
    {
        name: "TV Shows",
        href: "/tvshows",
        active: currentPath.startsWith("/tvshows"),
    },
    { name: "My List", href: "/list", active: currentPath.startsWith("/list") },
];
---

<nav class="hidden lg:flex items-center space-x-8">
    <ul class="flex items-center gap-6">
        {
            navItems.map((item) => (
                <li>
                    <a
                        href={item.href}
                        class:list={[
                            "text-base transition-colors duration-200 hover:drop-shadow-[0_0_15px_rgba(230,30,30,0.8)]",
                            item.active
                                ? "text-flow-accent drop-shadow-[0_0_15px_rgba(230,30,30,0.2)] font-[800]"
                                : "text-flow-sub hover:text-white",
                        ]}
                    >
                        {item.name}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>
