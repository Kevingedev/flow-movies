---
import Logo from "./header/Logo.astro";
import Navigation from "./header/Navigation.astro";
import SearchBar from "./header/SearchBar.astro";
import UserActions from "./header/UserActions.astro";
import MobileMenu from "./header/MobileMenu.astro";
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-flow-bg/80 backdrop-blur-md border-b border-white/5 shadow-lg shadow-black/20 transition-all duration-300"
>
    <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-12">
        <div class="flex items-center justify-between h-20">
            <!-- Left: Mobile Menu & Logo -->
            <div class="flex-shrink-0 flex items-center gap-4">
                <button
                    id="open-menu"
                    class="lg:hidden p-2 -ml-2 text-white hover:bg-white/10 rounded-md transition-colors"
                    aria-label="Open menu"
                >
                    <svg
                        class="w-7 h-7"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
                <Logo />
            </div>

            <!-- Center: Navigation (Desktop) -->
            <div class="hidden lg:flex flex-1 justify-center px-8">
                <Navigation />
            </div>

            <!-- Right: Search & Actions -->
            <div
                class="flex items-center justify-end gap-x-2 sm:gap-x-4 lg:gap-x-6"
            >
                <SearchBar />
                <div class="w-px h-6 bg-gray-800 hidden md:block"></div>
                <div class="hidden sm:block">
                    <UserActions />
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Move MobileMenu outside the header to avoid backdrop-filter stacking context issues -->
<MobileMenu />

<!-- Spacer to prevent content overlap since header is fixed -->
<div class="h-20"></div>
