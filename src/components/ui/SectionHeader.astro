---
interface Props {
    title: string;
    badge?: string;
    pulse?: boolean;
}

const { title, badge, pulse } = Astro.props;
---

<div
    class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-5"
>
    <div class="flex items-center gap-4">
        <div
            class="w-1.5 h-10 bg-flow-accent rounded-full shadow-[0_0_15px_rgba(220,38,38,0.5)]"
        >
        </div>
        <h2
            class="text-3xl sm:text-4xl font-bold tracking-tight text-white italic"
        >
            {title}
        </h2>
    </div>

    {
        (badge || pulse) && (
            <div class="flex items-center gap-3 bg-white/5 backdrop-blur-md px-4 py-2 rounded-2xl border border-white/10 self-start sm:self-auto">
                {pulse && (
                    <span class="relative flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-flow-accent/60 opacity-75" />
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-flow-accent" />
                    </span>
                )}
                {badge && (
                    <span class="text-xs font-bold text-flow-accent uppercase tracking-[0.2em]">
                        {badge}
                    </span>
                )}
            </div>
        )
    }
</div>
