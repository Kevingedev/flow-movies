---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import type { Movie } from "../../types/movie";

interface Props {
    movie: Movie;
    class?: string;
}

const { movie, class: className } = Astro.props;
const posterUrl = movie.poster_path
    ? `https://image.tmdb.org/t/p/w500${movie.poster_path}`
    : null;
const releaseYear = movie.release_date
    ? new Date(movie.release_date).getFullYear()
    : "N/A";
---

<a
    href={`/movie/${movie.id}`}
    aria-label={`Ver detalles de ${movie.title}`}
    class:list={[
        "group relative block aspect-[2/3] rounded-2xl overflow-hidden cursor-pointer",
        "transition-all duration-300 ease-out",
        "hover:scale-105 hover:brightness-110",
        "md:hover:border md:border-transparent md:hover:border-flow-accent/50", // Border red subtle on desktop
        "focus:outline-none focus:ring-2 focus:ring-flow-accent",
        className,
    ]}
>
    <!-- Background Image -->
    <div
        class="absolute inset-0 bg-gray-900 animate-pulse group-hover:animate-none"
    >
        {
            posterUrl ? (
                <Image
                    src={posterUrl}
                    alt={movie.title}
                    width={500}
                    height={750}
                    class="w-full h-full object-cover"
                    loading="lazy"
                />
            ) : (
                <div class="w-full h-full flex items-center justify-center text-gray-500">
                    <Icon name="lucide:image-off" class="size-10" />
                </div>
            )
        }
    </div>

    <!-- Micro-interaction: Top Corner Info -->
    <div
        class="absolute top-2 right-2 flex items-center gap-1.5 bg-black/40 backdrop-blur-md px-2 py-1 rounded-lg border border-white/10 z-10 transition-opacity duration-300"
    >
        <Icon name="lucide:star" class="size-3 text-yellow-500 fill-current" />
        <span class="text-xs font-semibold text-white"
            >{movie.vote_average.toFixed(1)}</span
        >
        <span
            class="text-[10px] text-gray-300 ml-1 border-l border-white/20 pl-1"
            >{releaseYear}</span
        >
    </div>

    <!-- Title Overlay (richer dark gradient for better contrast) -->
    <div
        class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
    >
    </div>

    <div class="absolute bottom-0 left-0 right-0 p-4">
        <h3
            class="text-white text-sm font-bold line-clamp-1 group-hover:text-flow-accent transition-colors"
        >
            {movie.title}
        </h3>
    </div>
</a>
