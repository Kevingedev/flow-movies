---
import { Image } from "astro:assets";
import type { WatchProviders } from "../../types/movie";

interface Props {
    providers: { [key: string]: WatchProviders } | null;
    country?: string;
}

const { providers, country = "ES" } = Astro.props;

const countryProviders = providers ? providers[country] : null;

const hasProviders =
    countryProviders &&
    (countryProviders.flatrate?.length ||
        countryProviders.rent?.length ||
        countryProviders.buy?.length);

// Helper to remove duplicates if necessary, although TMDB usually sends unique lists per category
const createUniqueList = (list: any[]) => list;
---

{
    hasProviders ? (
        <div class="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200">
            <h3 class="text-xl font-bold text-white flex items-center gap-2">
                <span class="w-1 h-6 bg-flow-accent rounded-full" />
                Disponible en
            </h3>

            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm">
                <div class="space-y-8">
                    {/* Streaming (Flatrate) */}
                    {countryProviders?.flatrate && (
                        <div>
                            <h4 class="text-sm font-medium text-gray-400 mb-3 uppercase tracking-wider">
                                Streaming
                            </h4>
                            <div class="flex flex-wrap gap-4">
                                {countryProviders.flatrate.map((provider) => (
                                    <div
                                        class="group relative"
                                        title={provider.provider_name}
                                    >
                                        <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl overflow-hidden shadow-lg border border-white/10 transition-transform duration-300 group-hover:scale-110 group-hover:border-flow-accent">
                                            <Image
                                                src={`https://image.tmdb.org/t/p/original${provider.logo_path}`}
                                                alt={provider.provider_name}
                                                width={60}
                                                height={60}
                                                class="w-full h-full object-cover"
                                            />
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    )}

                    {/* Rent */}
                    {countryProviders?.rent && (
                        <div>
                            <h4 class="text-sm font-medium text-gray-400 mb-3 uppercase tracking-wider">
                                Alquilar
                            </h4>
                            <div class="flex flex-wrap gap-4">
                                {countryProviders.rent.map((provider) => (
                                    <div
                                        class="group relative"
                                        title={provider.provider_name}
                                    >
                                        <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl overflow-hidden shadow-lg border border-white/10 transition-transform duration-300 group-hover:scale-110 group-hover:border-flow-accent">
                                            <Image
                                                src={`https://image.tmdb.org/t/p/original${provider.logo_path}`}
                                                alt={provider.provider_name}
                                                width={60}
                                                height={60}
                                                class="w-full h-full object-cover"
                                            />
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    )}

                    {/* Buy */}
                    {countryProviders?.buy && (
                        <div>
                            <h4 class="text-sm font-medium text-gray-400 mb-3 uppercase tracking-wider">
                                Comprar
                            </h4>
                            <div class="flex flex-wrap gap-4">
                                {countryProviders.buy.map((provider) => (
                                    <div
                                        class="group relative"
                                        title={provider.provider_name}
                                    >
                                        <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl overflow-hidden shadow-lg border border-white/10 transition-transform duration-300 group-hover:scale-110 group-hover:border-flow-accent">
                                            <Image
                                                src={`https://image.tmdb.org/t/p/original${provider.logo_path}`}
                                                alt={provider.provider_name}
                                                width={60}
                                                height={60}
                                                class="w-full h-full object-cover"
                                            />
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    )}
                </div>

                <div class="mt-6 pt-4 border-t border-white/5 text-right">
                    <a
                        href={countryProviders?.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs text-flow-sub hover:text-white transition-colors"
                    >
                        Datos proporcionados por JustWatch
                    </a>
                </div>
            </div>
        </div>
    ) : (
        <div class="p-6 bg-white/5 border border-white/10 rounded-2xl text-center backdrop-blur-sm">
            <p class="text-gray-400">
                No hay información de disponibilidad en esta región.
            </p>
        </div>
    )
}
