---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getNowPlayingMovies } from "../services/tmdb";

const movies = await getNowPlayingMovies();
// Take the first 2 movies, or specifically select impactful ones if needed.
// For now, we take the top 2 from Now Playing.
// console.log(movies);
const promoMovies = movies
                    .sort((a, b) => new Date(b.release_date).getTime() - new Date(a.release_date).getTime())
                    .slice(0, 2);
console.log(promoMovies);
const labels = ["NUEVO ESTRENO", "MÁS VISTO"];
---

<section class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-12 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
            promoMovies.map((movie, index) => (
                <div class="relative w-full h-[300px] md:h-[350px] rounded-3xl overflow-hidden group border border-white/10 bg-gray-900 shadow-2xl">
                    <!-- Background Image with Zoom Effect (Desktop Only) -->
                    <div class="absolute inset-0 overflow-hidden rounded-3xl">
                         <Image
                            src={`https://image.tmdb.org/t/p/original${movie.backdrop_path}`}
                            alt={movie.title}
                            width={1280}
                            height={720}
                            class="w-full h-full object-cover transition-transform duration-700 ease-in-out md:group-hover:scale-105"
                        />
                    </div>

                    <!-- Gradient Overlay (Left to Right) -->
                    <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-black/95 via-black/50 to-transparent pointer-events-none" />

                    <!-- Content -->
                    <div class="relative z-10 h-full flex flex-col justify-center items-center md:items-start p-6 md:p-12 text-center md:text-left">
                        <!-- Label -->
                        <span class="text-flow-accent font-bold uppercase tracking-wider text-xs md:text-sm mb-2 md:mb-3">
                            {labels[index] || "PROMOCIÓN"}
                        </span>

                        <!-- Title -->
                        <h2 class="text-2xl md:text-4xl font-black text-white mb-2 md:mb-3 leading-tight max-w-[90%] md:max-w-[80%] drop-shadow-lg">
                            {movie.title}
                        </h2>

                        <!-- Description (Short) -->
                        <p class="text-gray-300 text-sm md:text-lg font-medium line-clamp-2 md:line-clamp-2 max-w-sm mb-6 md:mb-8 text-pretty">
                            {movie.overview}
                        </p>

                        <!-- CTA Button -->
                        <a
                            href={`/movie/${movie.id}`}
                            class="flex items-center gap-2 px-6 py-2.5 md:py-3 rounded-full backdrop-blur-md bg-white/10 border border-white/20 text-white font-semibold transition-all duration-300 ease-in-out md:group-hover:bg-flow-accent md:group-hover:border-flow-accent md:hover:shadow-lg md:hover:shadow-flow-accent/30 md:group-hover:scale-105 active:scale-95"
                        >
                            <span>Ver Ahora</span>
                            <Icon name="lucide:play" class="size-4 fill-current" />
                        </a>
                    </div>
                </div>
            ))
        }
    </div>
</section>
