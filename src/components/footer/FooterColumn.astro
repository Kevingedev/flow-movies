---
interface Props {
    title: string;
    links: { label: string; href: string }[];
}

const { title, links } = Astro.props;
---

<div class="flex flex-col gap-4">
    <h3 class="text-white font-bold text-sm uppercase tracking-widest">
        {title}
    </h3>
    <ul class="flex flex-col gap-2">
        {
            links.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class="text-flow-sub hover:text-white hover:drop-shadow-[0_0_15px_rgba(220,38,38,0.7)] transition-colors duration-300 text-sm font-medium inline-block"
                    >
                        {link.label}
                    </a>
                </li>
            ))
        }
    </ul>
</div>
