---
import { Icon } from "astro-icon/components";

---

<div class="flex items-center gap-4">
    <a
        href="#"
        class="text-flow-sub hover:text-flow-accent/80 transition-all duration-300 hover:scale-110"
        aria-label="Instagram"
    >
        <Icon name="lucide:instagram" class="w-5 h-5" />
    </a>
    <a
        href="#"
        class="text-flow-sub hover:text-flow-accent/80 transition-all duration-300 hover:scale-110"
        aria-label="X (Twitter)"
    >
        <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            viewBox="0 0 24 24"
        >
            <path
                d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768m2.464-2.464L20 4"
            ></path>
        </svg>
    </a>
    <a
        href="#"
        class="text-flow-sub hover:text-flow-accent/80 transition-all duration-300 hover:scale-110"
        aria-label="YouTube"
    >
        <Icon name="lucide:youtube" class="w-5 h-5" />
    </a>
</div>
